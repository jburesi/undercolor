{
  "name": "undercolor",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "husky",
    "lint:eslint": "eslint .",
    "lint:eslint:fix": "eslint . --fix",
    "lint:format": "prettier . --check --ignore-unknown",
    "lint:format:fix": "prettier . --write --list-different --ignore-unknown",
    "lint:md": "markdownlint \"**/*.md\"",
    "lint:md:fix": "markdownlint \"**/*.md\" --fix",
    "lint": "pnpm lint:eslint && pnpm lint:format && pnpm lint:md",
    "lint:fix": "pnpm lint:eslint:fix && pnpm lint:format:fix && pnpm lint:md:fix",
    "supabase:gen": "supabase gen types typescript --local > src/app/types/database.types.ts"
  },
  "lint-staged": {
    "**/*": [
      "pnpm run lint:eslint:fix",
      "pnpm run lint:format:fix"
    ],
    "*.md": [
      "pnpm run lint:md:fix"
    ]
  },
  "dependencies": {
    "@nuxt/fonts": "0.12.1",
    "@nuxt/icon": "2.1.0",
    "@nuxt/image": "2.0.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/i18n": "10.2.1",
    "@nuxtjs/seo": "3.2.2",
    "@nuxtjs/supabase": "2.0.1",
    "@tailwindcss/vite": "^4.1.17",
    "@vee-validate/nuxt": "4.15.1",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.1.0",
    "@vueuse/nuxt": "14.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.555.0",
    "nuxt": "^4.2.1",
    "reka-ui": "^2.6.0",
    "shadcn-nuxt": "https://pkg.pr.new/shadcn-nuxt@1418",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.25",
    "vue-router": "^4.6.3",
    "vue-sonner": "^2.0.9",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@iconify-json/lucide": "^1.2.77",
    "@nuxt/eslint": "1.11.0",
    "eslint": "^9.39.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "markdownlint": "^0.39.0",
    "markdownlint-cli": "^0.46.0",
    "prettier": "3.7.3",
    "supabase": "^2.63.1",
    "typescript": "^5.9.3"
  }
}
