{
  "name": "undercolor",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "husky",
    "lint:eslint": "eslint .",
    "lint:eslint:fix": "eslint . --fix",
    "lint:format": "prettier . --check --ignore-unknown",
    "lint:format:fix": "prettier . --write --list-different --ignore-unknown",
    "lint:md": "markdownlint \"**/*.md\"",
    "lint:md:fix": "markdownlint \"**/*.md\" --fix",
    "lint": "pnpm lint:eslint && pnpm lint:format && pnpm lint:md",
    "lint:fix": "pnpm lint:eslint:fix && pnpm lint:format:fix && pnpm lint:md:fix",
    "supabase:gen": "supabase gen types typescript --local > src/shared/types/database.types.ts"
  },
  "lint-staged": {
    "**/*": [
      "pnpm run lint:eslint:fix",
      "pnpm run lint:format:fix"
    ],
    "*.md": [
      "pnpm run lint:md:fix"
    ]
  },
  "dependencies": {
    "@nuxt/fonts": "0.12.1",
    "@nuxt/icon": "2.2.0",
    "@nuxt/image": "2.0.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/i18n": "10.2.1",
    "@nuxtjs/seo": "3.3.0",
    "@nuxtjs/supabase": "2.0.3",
    "@tailwindcss/vite": "^4.1.18",
    "@vee-validate/nuxt": "5.0.0-beta.0",
    "@vueuse/core": "^14.1.0",
    "@vueuse/nuxt": "14.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jwt-decode": "^4.0.0",
    "lucide-vue-next": "^0.562.0",
    "nuxt": "^4.2.2",
    "reka-ui": "^2.7.0",
    "shadcn-nuxt": "https://pkg.pr.new/shadcn-nuxt@1418",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "vee-validate": "5.0.0-beta.0",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4",
    "vue-sonner": "^2.0.9",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@iconify-json/lucide": "^1.2.85",
    "@nuxt/eslint": "1.12.1",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "markdownlint": "^0.40.0",
    "markdownlint-cli": "^0.47.0",
    "prettier": "3.7.4",
    "supabase": "^2.72.7",
    "typescript": "^5.9.3"
  }
}
